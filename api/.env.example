# Portal API — variáveis de ambiente (valores REAIS só no EasyPanel/cofre, nunca no repo)
PORT=3001
# Conexão direta ao Postgres do Portal (pooler Supabase). Valor no cofre Portal_Cliente_SECRETS.
DATABASE_URL=postgresql://postgres.vqulwouxwtfpboifhwcl:__DB_PASSWORD__@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
# IdP = Supabase Auth do Portal (JWKS pública, valida o JWT do usuário)
SUPABASE_URL=https://vqulwouxwtfpboifhwcl.supabase.co
# opcional: IDP_JWKS_URL / IDP_ISSUER se o SSO mudar
# service_role key do Portal (para asService — ações de sistema). Valor no cofre.
PORTAL_SERVICE_KEY=__SERVICE_ROLE_KEY__
# CORS: origens do front do Portal
CORS_ORIGINS=https://portal.crasto.ai,http://localhost:5178,http://localhost:4173
